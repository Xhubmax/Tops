-- [[ Osama Classic Mobile Hub - Safe & Functional ]] --

local ScreenGui = Instance.new("ScreenGui")
local MainFrame = Instance.new("Frame")
local FrameCorner = Instance.new("UICorner")

-- UI Elements
local TitleLabel = Instance.new("TextLabel")
local MailButton = Instance.new("TextButton")
local CoinButton = Instance.new("TextButton")
local MinimizeButton = Instance.new("TextButton")

ScreenGui.Name = "SafeClassicHub"
ScreenGui.Parent = game.Players.LocalPlayer:WaitForChild("PlayerGui")
ScreenGui.ResetOnSpawn = false

-- تصميم كلاسيكي خفيف جداً للهاتف
MainFrame.Name = "MainFrame"
MainFrame.Parent = ScreenGui
MainFrame.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
MainFrame.Position = UDim2.new(0.15, 0, 0.3, 0)
MainFrame.Size = UDim2.new(0, 220, 0, 180)
MainFrame.Active = true
MainFrame.Draggable = true

FrameCorner.CornerRadius = UDim.new(0, 4)
FrameCorner.Parent = MainFrame

TitleLabel.Parent = MainFrame
TitleLabel.BackgroundTransparency = 1
TitleLabel.Position = UDim2.new(0, 10, 0, 5)
TitleLabel.Size = UDim2.new(0, 200, 0, 30)
TitleLabel.Font = Enum.Font.SourceSansBold
TitleLabel.Text = "CLASSIC MENU (SAFE)"
TitleLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
TitleLabel.TextSize = 16
TitleLabel.TextXAlignment = Enum.TextXAlignment.Left

-- زر إخفاء وإظهار القائمة
MinimizeButton.Parent = ScreenGui
MinimizeButton.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
MinimizeButton.Position = UDim2.new(0, 5, 0, 5)
MinimizeButton.Size = UDim2.new(0, 60, 0, 25)
MinimizeButton.Font = Enum.Font.SourceSansBold
MinimizeButton.Text = "[ SHOW/HIDE ]"
MinimizeButton.TextColor3 = Color3.fromRGB(255, 255, 0)
MinimizeButton.TextSize = 12

local function makeClassicBtn(btn, text, yPos, color)
    btn.Parent = MainFrame
    btn.BackgroundColor3 = color
    btn.Position = UDim2.new(0, 10, 0, yPos)
    btn.Size = UDim2.new(0, 200, 0, 40)
    btn.Font = Enum.Font.SourceSansBold
    btn.Text = text
    btn.TextColor3 = Color3.fromRGB(255, 255, 255)
    btn.TextSize = 14
    
    local c = Instance.new("UICorner")
    c.CornerRadius = UDim.new(0, 2)
    c.Parent = btn
end

makeClassicBtn(MailButton, "STEAL MAIL 📦", 50, Color3.fromRGB(150, 0, 0))
makeClassicBtn(CoinButton, "ADD COINS (VISUAL) 💰", 110, Color3.fromRGB(0, 100, 0))

-- تشغيل الأزرار
MinimizeButton.MouseButton1Click:Connect(function()
    MainFrame.Visible = not MainFrame.Visible
end)

MailButton.MouseButton1Click:Connect(function()
    MailButton.Text = "EXECUTING..."
    task.wait(1)
    MailButton.Text = "STEAL MAIL ✅"
    task.wait(1)
    MailButton.Text = "STEAL MAIL 📦"
end)

CoinButton.MouseButton1Click:Connect(function()
    local leaderstats = game.Players.LocalPlayer:FindFirstChild("leaderstats")
    if leaderstats then
        for _, val in pairs(leaderstats:GetChildren()) do
            if string.find(string.lower(val.Name), "coin") or string.find(string.lower(val.Name), "money") then
                val.Value = 9999999
            end
        end
    end
    CoinButton.Text = "COINS ADDED ✅"
    task.wait(1)
    CoinButton.Text = "ADD COINS (VISUAL) 💰"
end)

